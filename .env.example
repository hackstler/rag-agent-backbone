# ============================================================
# rag-agent-backbone — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ============================================================

# ------------------------------------------------------------
# DATABASE (requerido)
# Local:  postgresql://dev:dev@localhost:5432/ragdb
# Prod:   Supabase connection string (con ?sslmode=require)
# ------------------------------------------------------------
DATABASE_URL=postgresql://dev:dev@localhost:5432/ragdb

# ------------------------------------------------------------
# LLM — Producción (al menos uno requerido en prod)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...          # Claude 3.5 Sonnet
OPENAI_API_KEY=sk-...                 # GPT-4o + embeddings

# ------------------------------------------------------------
# LLM — Local (Ollama, sin API key)
# Requiere: docker-compose up ollama
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
NODE_ENV=development                   # development | production
PORT=3000
LOG_LEVEL=info                         # debug | info | warn | error

# ------------------------------------------------------------
# RAG CONFIG (sobreescribe src/config/rag.config.ts si se define)
# ------------------------------------------------------------
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# ------------------------------------------------------------
# OBSERVABILIDAD (opcional)
# ------------------------------------------------------------
# Langfuse (open-source, recomendado)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# LangSmith (alternativa)
# LANGSMITH_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true

# ------------------------------------------------------------
# RERANKING (opcional)
# ------------------------------------------------------------
# Cohere reranker (+20-35% precisión, +200ms latencia)
# COHERE_API_KEY=...

# ------------------------------------------------------------
# AUTENTICACIÓN (opcional — deshabilitada por defecto)
# ------------------------------------------------------------
# API_KEY=tu-api-key-secreta
# JWT_SECRET=secret-para-jwt
