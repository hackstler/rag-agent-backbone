# ============================================================
# rag-agent-backbone — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ============================================================

# ------------------------------------------------------------
# DATABASE (requerido)
# Local:  postgresql://dev:dev@localhost:5432/ragdb
# Prod:   Supabase connection string (con ?sslmode=require)
# ------------------------------------------------------------
DATABASE_URL=postgresql://dev:dev@localhost:5432/ragdb

# ------------------------------------------------------------
# LLM + Embeddings — Gemini (requerido)
# ------------------------------------------------------------
GOOGLE_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash   # o gemini-2.0-flash, gemini-1.5-pro

# ------------------------------------------------------------
# YouTube Data API v3 (requerido para ingestar vídeos de YouTube)
# Puede ser la misma GOOGLE_API_KEY si tienes YouTube Data API v3 habilitada
# en el mismo proyecto. Habilitar en:
# console.cloud.google.com → APIs & Services → Library → "YouTube Data API v3"
# ------------------------------------------------------------
# YOUTUBE_API_KEY=        # dejar vacío para reutilizar GOOGLE_API_KEY

# ------------------------------------------------------------
# LLM + Embeddings — OpenAI (alternativa, prod)
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# Web search fallback — Perplexity (opcional)
# Usado por searchWeb tool cuando searchDocuments no encuentra resultados
# ------------------------------------------------------------
# PERPLEXITY_API_KEY=pplx-...

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
NODE_ENV=development             # development | production
PORT=3000

# ------------------------------------------------------------
# AGENT IDENTITY (opcional — valores por defecto son genéricos)
# ------------------------------------------------------------
# AGENT_NAME=RAG Agent
# AGENT_DESCRIPTION=A production-ready RAG agent that answers questions based on your documents.
# AGENT_LANGUAGE=en       # en | es | fr | de | ...

# ------------------------------------------------------------
# RAG CONFIG
# ------------------------------------------------------------
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.5
# RAG_QUERY_ENHANCEMENT=multi-query   # none | multi-query | hyde | step-back
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=50

# ------------------------------------------------------------
# YOUTUBE INGESTION (opcional)
# ------------------------------------------------------------
# YOUTUBE_API_KEY=AIzaSy...          # YouTube Data API v3 (para metadatos)
# VISION_AI_PROMPT=Describe en detalle...  # Prompt para Vision AI cuando no hay transcript

# ------------------------------------------------------------
# RERANKING (opcional — +20-35% precisión, +200ms latencia)
# ------------------------------------------------------------
# COHERE_API_KEY=...

# ------------------------------------------------------------
# OBSERVABILIDAD (opcional)
# ------------------------------------------------------------
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ------------------------------------------------------------
# AUTENTICACIÓN (opcional — deshabilitada si no se configuran)
# Ambos métodos pueden coexistir:
#   X-API-Key         → machine-to-machine (WhatsApp listener, scripts)
#   Bearer JWT        → user sessions (dashboard)
# Genera secrets con: openssl rand -hex 32
# ------------------------------------------------------------
# API_KEY=tu-api-key-secreta
# JWT_SECRET=tu-secreto-jwt-largo-y-aleatorio
