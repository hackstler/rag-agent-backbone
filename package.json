{
  "name": "rag-agent-backbone",
  "version": "0.1.0",
  "description": "Production-ready RAG agent template — configure once, deploy anywhere",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:pg-native",
    "start": "node dist/index.js",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "seed": "tsx src/db/seed.ts",
    "ingest": "tsx src/ingestion/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.30",
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.8.0",
    "@mastra/core": "^1.5.0",
    "@mastra/memory": "^1.4.0",
    "@mastra/pg": "^1.5.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "langfuse": "^3.0.0",
    "mammoth": "^1.7.0",
    "openai": "^4.0.0",
    "pdfjs-dist": "^4.0.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
